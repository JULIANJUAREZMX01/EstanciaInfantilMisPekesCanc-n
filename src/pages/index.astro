      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">Resolvemos tus dudas</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Preguntas Frecuentes</h2>
        </div>
        <FAQIsland client:visible />
      </div>
    </section>

    <!-- TIENDA PREVIEW -->
    <section id="tienda" style="background: #f8faf9;" class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(255,140,66,0.12); color: #ff8c42;">Tienda</span>
          <h2 class="text-3xl font-extrabold text-slate-800 mb-3">Artículos Disponibles</h2>
          <p class="text-slate-500 text-sm">Productos de primera necesidad disponibles para compra en el Portal</p>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-5 mb-8">
