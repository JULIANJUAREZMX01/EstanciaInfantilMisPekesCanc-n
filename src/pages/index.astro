    <!-- PAQUETES -->
    <section id="paquetes" style="background: #f8faf9;" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-14">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">Planes de cuidado</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800 mb-3">Elige el Paquete Ideal</h2>
          <p class="text-slate-500 text-sm max-w-md mx-auto">Todos los paquetes incluyen cuidado, enseñanza, educación y pedagogía. Elige el que mejor se adapte a tu familia.</p>
        </div>
        <PricingCards client:visible />
        <p class="text-center text-xs text-slate-400 mt-8">
          &#x1F4A1; Precios y disponibilidad confirmados al inscribirse · Bebida/leche/fórmula: responsabilidad del tutor
        </p>
      </div>
    </section>

    <!-- JUEGOS -->
    <section id="juegos" class="bg-white py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">¡A jugar!</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800 mb-3">Zona de Aprendizaje Interactivo</h2>
          <p class="text-slate-500 text-sm max-w-md mx-auto">Minijuegos educativos que estimulan el desarrollo cognitivo y la coordinación motriz</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="reveal-card">
            <div class="flex items-center gap-3 mb-4 px-1">
              <span class="text-3xl" aria-hidden="true">&#x1FAE7;</span>
              <div>
                <h3 class="font-extrabold text-slate-800">Atrapa Burbujas</h3>
                <p class="text-slate-500 text-xs">Coordinación motriz y velocidad visual</p>
              </div>
            </div>
            <BubbleGame client:visible />
          </div>
          <div class="reveal-card">
            <div class="flex items-center gap-3 mb-4 px-1">
              <span class="text-3xl" aria-hidden="true">&#x1F308;</span>
              <div>
                <h3 class="font-extrabold text-slate-800">Aprende Colores</h3>
                <p class="text-slate-500 text-xs">Reconocimiento visual y asociación cognitiva</p>
              </div>
            </div>
            <ColorGame client:visible />
          </div>
        </div>
      </div>
    </section>

    <!-- MISIÓN Y VISIÓN -->
    <section style="background: #f8faf9;" class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Misión y Visión</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="reveal-card rounded-3xl p-8 shadow-sm"
            style="background: linear-gradient(135deg, #f0fdf9, #e0faf4); border: 1px solid rgba(0,184,160,0.15);">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl mb-5" style="background: rgba(0,184,160,0.15);">&#x1F3AF;</div>
            <h3 class="text-xl font-extrabold mb-3" style="color: #00b8a0;">Misión</h3>
            <p class="text-slate-600 leading-relaxed text-sm">Brindar un entorno seguro, afectuoso y estimulante donde cada niño pueda desarrollar sus capacidades cognitivas, emocionales y físicas. Somos el apoyo fundamental de las familias trabajadoras de Cancún.</p>
          </div>
          <div class="reveal-card rounded-3xl p-8 shadow-sm"
            style="background: linear-gradient(135deg, #f0f4ff, #e8edfa); border: 1px solid rgba(69,123,157,0.15);">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl mb-5" style="background: rgba(69,123,157,0.12);">&#x1F52D;</div>
            <h3 class="text-xl font-extrabold mb-3 text-slate-700">Visión</h3>
            <p class="text-slate-600 leading-relaxed text-sm">Consolidarnos como la estancia infantil líder en la Región 91, reconocidos por nuestra excelencia educativa, calidez humana e innovación constante en técnicas de estimulación temprana.</p>
          </div>
        </div>
      </div>
    </section>

