    function renderMayaDict(filter: string) {
      const grid = document.getElementById('mayaDictGrid');
      if (!grid) return;
      const list = filter === 'all' ? mayaData : mayaData.filter(e => e.cat === filter);
      grid.innerHTML = list.map(e => {
        const safeWord = e.maya.replace(/'/g, '&#39;').replace(/"/g, '&quot;');
        return `
        <div class="maya-card fade-in" onclick="speakMaya(this.dataset.maya)" data-maya="${safeWord}">
          <button class="maya-speak-btn" onclick="event.stopPropagation();speakMaya(this.parentElement.dataset.maya)" aria-label="Escuchar pronunciación">🔊</button>
          <span class="maya-card-glyph">${e.glyph}</span>
          <span class="maya-card-word">${e.maya}</span>
          <span class="maya-card-phonetic">[${e.phonetic}]</span>
          <span class="maya-card-spanish">${e.spanish}</span>
          <span class="maya-card-cat">${e.cat}</span>
        </div>`;
      }).join('');
      grid.querySelectorAll('.fade-in').forEach(el => fadeObserver.observe(el));
    }

    function filterMaya(cat: string, btn: HTMLElement) {
      document.querySelectorAll('.maya-cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderMayaDict(cat);
    }
    (window as any).filterMaya = filterMaya;

    function speakMaya(text: string) {
      if (!window.speechSynthesis) return;
      window.speechSynthesis.cancel();
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = 'es-MX';
      utter.rate = 0.72;
      utter.pitch = 1.1;
      window.speechSynthesis.speak(utter);
    }
    (window as any).speakMaya = speakMaya;

    // ══ MAYA QUIZ ══
    let quizQs: typeof mayaData = [], quizIdx = 0, quizScore = 0;

    function startMayaQuiz() {
      quizScore = 0; quizIdx = 0;
      quizQs = [...mayaData].sort(() => Math.random() - .5).slice(0, 10);
      const mqStart = document.getElementById('mqStart');
      const mqComplete = document.getElementById('mqComplete');
      const mqQuestionArea = document.getElementById('mqQuestionArea');
      const mayaQuizWrapper = document.getElementById('mayaQuizWrapper');
      if (mqStart) mqStart.style.display = 'none';
      if (mqComplete) mqComplete.style.display = 'none';
      if (mqQuestionArea) mqQuestionArea.style.display = 'block';
      if (mayaQuizWrapper) mayaQuizWrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
      renderQuizQ();
    }
    (window as any).startMayaQuiz = startMayaQuiz;

    function renderQuizQ() {
      if (quizIdx >= quizQs.length) { endMayaQuiz(); return; }
      const q = quizQs[quizIdx];
      const total = quizQs.length;
      const mqCounter = document.getElementById('mqCounter');
      const mqFill = document.getElementById('mqFill') as HTMLElement;
      const mqScoreEl = document.getElementById('mqScore');
      const mqWord = document.getElementById('mqWord');
      const mqHint = document.getElementById('mqHint');
      const mqFeedback = document.getElementById('mqFeedback');
      const mqNextBtn = document.getElementById('mqNextBtn') as HTMLButtonElement;
      if (mqCounter) mqCounter.textContent = 'Pregunta ' + (quizIdx + 1) + ' / ' + total;
      if (mqFill) mqFill.style.width = ((quizIdx / total) * 100) + '%';
      if (mqScoreEl) mqScoreEl.textContent = quizScore + ' ⭐';
      if (mqWord) mqWord.textContent = q.maya;
      if (mqHint) mqHint.textContent = '¿Qué significa en español? (pronuncia: ' + q.phonetic + ')';
      if (mqFeedback) mqFeedback.textContent = '';
      if (mqNextBtn) mqNextBtn.style.display = 'none';
      const wrong = mayaData.filter(e => e !== q).sort(() => Math.random() - .5).slice(0, 3);
      const opts = [q, ...wrong].sort(() => Math.random() - .5);
      const container = document.getElementById('mqChoices');
      if (!container) return;
      container.innerHTML = '';
      opts.forEach(opt => {
        const b = document.createElement('button');
        b.className = 'mq-choice';
        b.textContent = opt.glyph + ' ' + opt.spanish;
        b.onclick = () => checkMayaQ(b, opt, q);
        container.appendChild(b);
      });
    }

    function checkMayaQ(btn: HTMLButtonElement, chosen: typeof mayaData[0], correct: typeof mayaData[0]) {
      document.querySelectorAll('.mq-choice').forEach((b: any) => { b.disabled = true; });
      const fb = document.getElementById('mqFeedback');
      const mqScoreEl = document.getElementById('mqScore');
      const mqNextBtn = document.getElementById('mqNextBtn') as HTMLButtonElement;
      if (chosen === correct) {
        btn.classList.add('correct');
        quizScore++;
        if (mqScoreEl) mqScoreEl.textContent = quizScore + ' ⭐';
        if (fb) { fb.textContent = '✅ ¡Correcto! ' + correct.glyph + ' ' + correct.maya + ' = ' + correct.spanish; fb.style.color = 'var(--teal-dark)'; }
        playSuccess();
      } else {
        btn.classList.add('wrong');
        document.querySelectorAll('.mq-choice').forEach((b: any) => {
          if (b.textContent.includes(correct.spanish)) b.classList.add('correct');
        });
        if (fb) { fb.textContent = '❌ Era: ' + correct.glyph + ' ' + correct.maya + ' = ' + correct.spanish; fb.style.color = 'var(--coral)'; }
      }
      if (mqNextBtn) mqNextBtn.style.display = 'block';
    }

    function nextQuizQ() { quizIdx++; renderQuizQ(); }
    (window as any).nextQuizQ = nextQuizQ;

    function endMayaQuiz() {
      const mqQuestionArea = document.getElementById('mqQuestionArea');
      const mqComplete = document.getElementById('mqComplete');
      const mqFill = document.getElementById('mqFill') as HTMLElement;
      const mqCompleteEmoji = document.getElementById('mqCompleteEmoji');
      const mqFinalScore = document.getElementById('mqFinalScore');
      const mqFinalMsg = document.getElementById('mqFinalMsg');
      if (mqQuestionArea) mqQuestionArea.style.display = 'none';
      if (mqComplete) mqComplete.style.display = 'block';
      if (mqFill) mqFill.style.width = '100%';
      const pct = (quizScore / quizQs.length) * 100;
      let emoji = '🌱', msg = '¡Sigue practicando! El maya es hermoso.';
      if (pct >= 90) { emoji = '🏆🎉🦋'; msg = '¡Excelente! ¡Eres un experto en maya yucateco!'; launchConfetti(); }
      else if (pct >= 70) { emoji = '⭐😊'; msg = '¡Muy bien! ¡Sigue practicando!'; }
      else if (pct >= 50) { emoji = '💛'; msg = '¡Bien! Pero puedes mejorar.'; }
      if (mqCompleteEmoji) mqCompleteEmoji.textContent = emoji;
      if (mqFinalScore) mqFinalScore.textContent = quizScore + '/' + quizQs.length + ' ⭐';
      if (mqFinalMsg) mqFinalMsg.textContent = msg;
    }

    // Initialize dictionary on load
    renderMayaDict('all');
  </script>

