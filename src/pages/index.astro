      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">¿Cómo llegar?</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Encuéntranos</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div class="rounded-3xl p-8 shadow-sm"
            style="background: linear-gradient(135deg, #f0fdf9, #e6faf6); border: 1px solid rgba(0,184,160,0.15);">
            <h3 class="text-xl font-extrabold mb-6" style="color: #00b8a0;">&#x1F4CD; Dirección</h3>
            <div class="space-y-4 text-sm text-slate-600">
              <div class="flex gap-3">
                <span class="text-lg flex-shrink-0">&#x1F3E0;</span>
                <div>
                  <p class="font-bold text-slate-800">Región 91, Manzana 48, Lote 8</p>
                  <p>Calle 38 Pte., C.P. 77516</p>
                  <p>Cancún, Quintana Roo</p>
                </div>
              </div>
              <div class="flex gap-3">
                <span class="text-lg flex-shrink-0">&#x1F4DE;</span>
                <div>
                  <p class="font-bold text-slate-800">Teléfono / WhatsApp</p>
