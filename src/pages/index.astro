      content: ''; flex: 1; max-width: 50px; height: 2px; background: currentColor; opacity: .3;
    }
    .sl-coral { color: var(--coral); }
    .sl-teal  { color: var(--teal-dark); }
    .sl-sun   { color: var(--sun); }
    h2.section-title {
      font-family: 'Baloo 2', cursive; font-size: clamp(1.8rem,3.5vw,2.6rem);
      font-weight: 800; color: var(--text); line-height: 1.2; margin-bottom: 1rem;
    }
    h2.section-title em { color: var(--coral); font-style: normal; }
    h2.section-title strong { color: var(--teal-dark); }
    .section-sub { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; max-width: 560px; }

    /* ── FADE-IN ── */
    .fade-in { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
    .fade-in.visible { opacity: 1; transform: none; }

    /* ══ JUEGOS INTERACTIVOS ══ */
    #juegos { background: linear-gradient(160deg, #EAF8FF 0%, #F0FBF7 100%); }
    .games-tabs {
      display: flex; justify-content: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;
    }
    .game-tab-btn {
      background: white; border: 2px solid #E8EDF5; border-radius: 50px;
      padding: .55rem 1.5rem; font-family: 'Nunito', sans-serif; font-weight: 700;
      font-size: .9rem; color: var(--text-light); cursor: pointer; transition: all .2s;
    }
    .game-tab-btn.active { background: var(--deep); color: white; border-color: var(--deep); }
    .game-tab-btn:hover:not(.active) { border-color: var(--sky); color: var(--deep); }
    .game-panel {
      background: white; border-radius: 28px; padding: 1.5rem 2rem;
      box-shadow: 0 8px 32px rgba(0,0,0,.08); max-width: 620px; margin: 0 auto;
      display: none;
    }
    .game-panel.active { display: block; }
    .game-topbar {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1rem; flex-wrap: wrap; gap: .5rem;
    }
    .game-stat-badge {
      font-family: 'Baloo 2', cursive; font-size: 1.15rem; font-weight: 800;
      background: var(--cream); border-radius: 12px; padding: .3rem .9rem;
    }
    .game-stat-badge.timer { color: var(--deep); }
    .game-stat-badge.score { color: var(--coral); }
    #bubbleCanvas {
      display: block; width: 100%; border-radius: 16px; cursor: crosshair;
      touch-action: none; background: linear-gradient(160deg, #E0F7FA, #E8F5E9);
    }
    .btn-game-action {
      background: linear-gradient(135deg, var(--coral), var(--coral-light));
      color: white; border: none; border-radius: 50px; padding: .75rem 2rem;
      font-family: 'Nunito', sans-serif; font-size: 1rem; font-weight: 700;
      cursor: pointer; box-shadow: 0 6px 20px rgba(255,107,107,.4);
      transition: all .3s; margin: 1rem auto 0; display: block;
    }
    .btn-game-action:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(255,107,107,.5); }
    .game-tip {
      text-align: center; font-size: .82rem; color: var(--text-light); margin-top: .6rem;
    }
    /* Color game */
    .cg-question { text-align: center; padding: .5rem 0 1.5rem; }
    .cg-spanish-word {
      font-family: 'Baloo 2', cursive; font-size: 2.5rem; font-weight: 800;
      color: var(--deep); display: block; margin-bottom: .2rem;
    }
    .cg-maya-hint { font-size: .88rem; color: var(--text-light); font-style: italic; }
    .cg-colors {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem;
    }
    .cg-color-btn {
      aspect-ratio: 1; border-radius: 18px; border: 3px solid transparent;
      cursor: pointer; transition: all .25s; box-shadow: 0 4px 16px rgba(0,0,0,.15);
    }
    .cg-color-btn:hover { transform: scale(1.08); }
    .cg-color-btn.correct { border-color: #2DC653 !important; box-shadow: 0 0 0 4px rgba(45,198,83,.3); }
    .cg-color-btn.wrong { border-color: var(--coral) !important; animation: cgShake .4s; }
    @keyframes cgShake {
      0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)}
    }
    .cg-score-display {
      text-align: center; font-weight: 700; font-size: 1rem;
      color: var(--teal-dark); min-height: 1.5rem;
    }

    /* ══ DICCIONARIO MAYA ══ */
    #maya { background: linear-gradient(160deg, #FFF9F0 0%, #F8F0FF 60%, #F0FBF8 100%); }
