---
import Layout from '../layouts/Layout.astro';
import NavbarIsland from '../components/NavbarIsland.tsx';
import PricingCards from '../components/PricingCards.tsx';
import FAQIsland from '../components/FAQIsland.tsx';
---

<Layout title="Estancia Infantil Mis Pekes | Cancún">

  <!-- NAVBAR -->
  <NavbarIsland client:load />

  <!-- HERO -->
  <header id="inicio" class="relative overflow-hidden text-white text-center"
    style="background: linear-gradient(135deg, #00d4b8 0%, #00b8a0 45%, #1a4d47 100%); padding: 6rem 1.5rem 7rem;">
    <div class="hero-bubbles" aria-hidden="true">
      <span class="bubble bubble-1"></span>
      <span class="bubble bubble-2"></span>
      <span class="bubble bubble-3"></span>
      <span class="bubble bubble-4"></span>
      <span class="bubble bubble-5"></span>
      <span class="bubble bubble-6"></span>
      <span class="star star-1">&#x2726;</span>
      <span class="star star-2">&#x2726;</span>
      <span class="star star-3">&#x2B50;</span>
    </div>
    <div class="max-w-2xl mx-auto relative z-10">
      <p class="inline-block bg-white/20 border border-white/30 text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6 animate-fade-in">
        &#x2728; Cancún · Región 91 · Desde 43 días de vida
      </p>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-5 animate-slide-up">
        Estancia Infantil<br />
        <span class="block mt-1"
          style="background: linear-gradient(135deg, #fff 0%, #d4fff8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 1.15em;">
          Mis Pekes &#x1F33B;
        </span>
      </h1>
      <p class="text-lg md:text-xl font-semibold mb-3 opacity-95 animate-fade-in-delay">
        "Creamos, Aprendemos y Crecemos Cada Día &#x1F331;"
      </p>
      <p class="text-sm leading-relaxed mb-10 opacity-85 max-w-lg mx-auto animate-fade-in-delay">
        En Mis Pekes, cada niño es un pekeño universo de posibilidades. Cuidado seguro,
        afectuoso y estimulante para bebés y preescolares en el corazón de Cancún.
      </p>
      <div class="flex gap-4 justify-center flex-wrap animate-fade-in-delay2">
        <a href="https://wa.me/5219982415799" target="_blank" rel="noopener noreferrer"
          class="bg-white font-bold text-sm px-8 py-3.5 rounded-full transition-all hover:scale-105 hover:shadow-xl"
          style="color: #00b8a0;">
          &#x1F4AC; Inscripciones
        </a>
        <a href="#paquetes"
          class="bg-transparent border-2 border-white text-white font-bold text-sm px-8 py-3.5 rounded-full transition-all hover:bg-white/20 hover:scale-105">
          Ver Paquetes &#x1F4CB;
        </a>
      </div>
      <div class="mt-14 flex justify-center animate-bounce" aria-hidden="true">
        <div class="w-7 h-11 rounded-full border-2 border-white/50 flex justify-center pt-2">
          <div class="w-1.5 h-2.5 bg-white/60 rounded-full scroll-dot"></div>
        </div>
      </div>
    </div>
  </header>

  <!-- QUICK INFO BAR -->
  <div style="background: #1a4d47;" class="py-7 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4 hover:bg-white/15 transition-colors">
        <span class="text-3xl" aria-hidden="true">&#x1F550;</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Horario</p>
          <p class="text-white text-sm font-bold mt-0.5">Lun–Vie · 7:00 AM – 5:00 PM</p>
          <p class="text-white/60 text-xs mt-0.5">Fines de semana disponibles</p>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4 hover:bg-white/15 transition-colors">
        <span class="text-3xl" aria-hidden="true">&#x1F476;</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Edades</p>
          <p class="text-white text-sm font-bold mt-0.5">43 días – 6 años</p>
          <p class="text-white/60 text-xs mt-0.5">Lactantes y preescolares</p>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4 hover:bg-white/15 transition-colors">
        <span class="text-3xl" aria-hidden="true">&#x1F4CD;</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Ubicación</p>
          <p class="text-white text-sm font-bold mt-0.5">Región 91, Cancún Q.R.</p>
          <p class="text-white/60 text-xs mt-0.5">C.P. 77516</p>
        </div>
      </div>
    </div>
  </div>

  <main>

    <!-- VALORES / NOSOTROS -->
    <section id="nosotros" class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
          style="background: rgba(0,184,160,0.1); color: #00b8a0;">Nuestra Filosofía</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Valores que nos Guían</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="reveal-card bg-white rounded-3xl border border-slate-100 shadow-sm p-7 hover:-translate-y-2 transition-all duration-300 hover:shadow-lg">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-5" style="background: rgba(0,184,160,0.1);">&#x1F512;</div>
          <h3 class="text-lg font-extrabold mb-2" style="color: #00b8a0;">Seguridad</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Espacios seguros, personal capacitado y protocolos de salud rigurosos para el bienestar integral.</p>
        </div>
        <div class="reveal-card bg-white rounded-3xl border border-slate-100 shadow-sm p-7 hover:-translate-y-2 transition-all duration-300 hover:shadow-lg" style="animation-delay:0.1s">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-5" style="background: rgba(0,184,160,0.1);">&#x1F49A;</div>
          <h3 class="text-lg font-extrabold mb-2" style="color: #00b8a0;">Confianza</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Comunicación transparente con padres. Reportes diarios y acceso a nuestros espacios.</p>
        </div>
        <div class="reveal-card bg-white rounded-3xl border border-slate-100 shadow-sm p-7 hover:-translate-y-2 transition-all duration-300 hover:shadow-lg" style="animation-delay:0.2s">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-5" style="background: rgba(0,184,160,0.1);">&#x1FAF6;</div>
          <h3 class="text-lg font-extrabold mb-2" style="color: #00b8a0;">Empatía</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Atención personalizada. Respetamos el ritmo y necesidades únicas de cada niño.</p>
        </div>
        <div class="reveal-card bg-white rounded-3xl border border-slate-100 shadow-sm p-7 hover:-translate-y-2 transition-all duration-300 hover:shadow-lg" style="animation-delay:0.3s">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-5" style="background: rgba(0,184,160,0.1);">&#x1F31F;</div>
          <h3 class="text-lg font-extrabold mb-2" style="color: #00b8a0;">Compromiso</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Desarrollo integral. Estimulación temprana con metodologías educativas comprobadas.</p>
        </div>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="bg-white py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">Lo que ofrecemos</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Nuestros Servicios</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="reveal-card bg-pekes-cream rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-2 hover:shadow-lg transition-all duration-300">
            <div class="h-32 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #ffd6a5, #ffb88c);">&#x1F37D;&#xFE0F;</div>
            <div class="p-6">
              <h3 class="font-extrabold text-base mb-2" style="color: #ff8c42;">Nutrición Balanceada</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Menús nutritivos con recetas caseras. Respetamos alergias y necesidades dietéticas.</p>
            </div>
          </div>
          <div class="reveal-card bg-pekes-cream rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-2 hover:shadow-lg transition-all duration-300" style="animation-delay:0.1s">
            <div class="h-32 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #a8dadc, #457b9d);">&#x1F4DA;</div>
            <div class="p-6">
              <h3 class="font-extrabold text-base mb-2" style="color: #457b9d;">Programa Educativo</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Estimulación temprana estructurada. Desarrollo de lenguaje, motricidad y habilidades cognitivas.</p>
            </div>
          </div>
          <div class="reveal-card bg-pekes-cream rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-2 hover:shadow-lg transition-all duration-300" style="animation-delay:0.2s">
            <div class="h-32 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #c1ffa9, #7bc043);">&#x26BD;</div>
            <div class="p-6">
              <h3 class="font-extrabold text-base mb-2" style="color: #7bc043;">Actividad Física</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Juego libre y psicomotricidad. Espacios seguros para correr, trepar y explorar.</p>
            </div>
          </div>
          <div class="reveal-card bg-pekes-cream rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-2 hover:shadow-lg transition-all duration-300" style="animation-delay:0.3s">
            <div class="h-32 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #ffc6ff, #ff6ec7);">&#x1F3A8;</div>
            <div class="p-6">
              <h3 class="font-extrabold text-base mb-2" style="color: #ff6ec7;">Expresión Creativa</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Arte, música y expresión libre. Fomentamos la creatividad sin límites.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PAQUETES -->
    <section id="paquetes" style="background: #f8faf9;" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-14">
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            style="background: rgba(0,184,160,0.1); color: #00b8a0;">Planes de cuidado</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800 mb-3">Elige el Paquete Ideal</h2>
          <p class="text-slate-500 text-sm max-w-md mx-auto">Todos los paquetes incluyen cuidado, enseñanza, educación y pedagogía. Elige el que mejor se adapte a tu familia.</p>
        </div>
        <PricingCards client:visible />
        <p class="text-center text-xs text-slate-400 mt-8">
          &#x1F4A1; Precios y disponibilidad confirmados al inscribirse · Bebida/leche/fórmula: responsabilidad del tutor
        </p>
      </div>
    </section>

    <!-- JUEGOS -->
    <section id="juegos">
      <div class="max-w">
        <div style="text-align:center; max-width:600px; margin:0 auto 3rem">
          <div class="section-label sl-teal fade-in" style="justify-content:center">Zona Interactiva</div>
          <h2 class="section-title fade-in">Juegos que <em>enseñan</em> y <strong>divierten</strong> 🎮</h2>
          <p class="section-sub fade-in" style="margin:0 auto; text-align:center">Actividades lúdico-educativas para desarrollar coordinación, colores y habilidades cognitivas</p>
        </div>

        <div class="games-tabs fade-in">
          <button class="game-tab-btn active" onclick="switchGame('bubble',this)">🫧 Atrapa Burbujas</button>
          <button class="game-tab-btn" onclick="switchGame('colors',this)">🌈 Aprende Colores Maya</button>
        </div>

        <!-- Bubble game -->
        <div id="game-bubble" class="game-panel active fade-in">
          <div class="game-topbar">
            <div class="game-stat-badge score" id="bubbleScore">🫧 0 puntos</div>
            <strong style="font-family:'Baloo 2',cursive;color:var(--deep);font-size:1.1rem">¡Atrapa las Burbujas!</strong>
            <div class="game-stat-badge timer" id="bubbleTimer">⏱ 30s</div>
          </div>
          <canvas id="bubbleCanvas" width="560" height="320"></canvas>
          <button class="btn-game-action" id="bubbleBtn" onclick="startBubbleGame()">▶ Iniciar Juego</button>
          <p class="game-tip">Haz clic o toca las burbujas antes de que desaparezcan · Desarrolla la coordinación motriz 👆</p>
        </div>

        <!-- Color game -->
        <div id="game-colors" class="game-panel fade-in">
          <div class="cg-question">
            <span class="cg-spanish-word" id="cgWord">¿Listo para jugar?</span>
            <span class="cg-maya-hint" id="cgMaya">Toca el color correcto en la cuadrícula</span>
          </div>
          <div class="cg-colors" id="cgGrid"></div>
          <div class="cg-score-display" id="cgScore"></div>
          <button class="btn-game-action" id="cgBtn" onclick="startColorGame()">▶ Iniciar Juego</button>
          <p class="game-tip">Selecciona el color correcto · Aprende los colores en español y en maya yucateco 🌈</p>
        </div>
      </div>
    </section>

    <!-- DICCIONARIO MAYA -->
    <section id="maya">
      <div class="max-w">

        <!-- Banner -->
        <div class="maya-banner fade-in">
          <h3>🌺 Mi Primer Peke Diccionario Maya 🌺</h3>
          <p>En Cancún somos parte de la rica cultura maya. Aprender la lengua maya yucateca es un orgullo que nos conecta con nuestras raíces y las de nuestra tierra. ¡Exploremos juntos las palabras de nuestros ancestros!</p>
        </div>

        <!-- Floating decorations -->
        <div class="maya-deco-row fade-in">
          <div class="maya-deco-item">☀️ K'in = Sol</div>
          <div class="maya-deco-item">💧 Ja' = Agua</div>
          <div class="maya-deco-item">🌺 Nich = Flor</div>
          <div class="maya-deco-item">⭐ Ek' = Estrella</div>
        </div>

        <!-- Category filters -->
        <div class="maya-cats fade-in" id="mayCats">
          <button class="maya-cat-btn active" onclick="filterMaya('all',this)">🌟 Todas</button>
          <button class="maya-cat-btn" onclick="filterMaya('saludos',this)">👋 Saludos</button>
          <button class="maya-cat-btn" onclick="filterMaya('familia',this)">👨‍👩‍👧 Familia</button>
          <button class="maya-cat-btn" onclick="filterMaya('naturaleza',this)">🌿 Naturaleza</button>
          <button class="maya-cat-btn" onclick="filterMaya('animales',this)">🐾 Animales</button>
          <button class="maya-cat-btn" onclick="filterMaya('comida',this)">🍽️ Comida</button>
          <button class="maya-cat-btn" onclick="filterMaya('colores',this)">🌈 Colores</button>
          <button class="maya-cat-btn" onclick="filterMaya('numeros',this)">🔢 Números</button>
          <button class="maya-cat-btn" onclick="filterMaya('sentimientos',this)">💛 Sentimientos</button>
        </div>

        <!-- Dictionary grid – populated by JS -->
        <div class="maya-dict-grid" id="mayaDictGrid"></div>

        <!-- Video resources -->
        <div style="text-align:center; margin:0 0 2rem">
          <div class="section-label sl-coral fade-in" style="justify-content:center">Aprende con Videos</div>
          <h2 class="section-title fade-in" style="text-align:center; font-size:clamp(1.5rem,3vw,2rem)">Recursos <em>Educativos</em> de Maya 📺</h2>
          <p class="section-sub fade-in" style="text-align:center; margin:0 auto">Videos recomendados para escuchar y practicar la lengua maya yucateca</p>
        </div>
        <div class="video-cards-grid fade-in">
          <a class="video-card" href="https://www.youtube.com/results?search_query=lengua+maya+yucateca+para+niños" target="_blank" rel="noopener" style="text-decoration:none">
            <div class="video-thumb" style="background:linear-gradient(135deg,#1A3C5E,#2d6a4f)">
              <span class="video-thumb-icon">🎙️</span>
              <div class="video-play-btn">▶</div>
            </div>
            <div class="video-card-body">
              <h4>Lengua Maya para Niños</h4>
              <p>Aprende palabras y frases básicas de maya yucateco con canciones y cuentos infantiles.</p>
            </div>
          </a>
          <a class="video-card" href="https://www.youtube.com/results?search_query=cancun+cultura+maya+tradiciones" target="_blank" rel="noopener" style="text-decoration:none">
            <div class="video-thumb" style="background:linear-gradient(135deg,#FFB800,#FF6B6B)">
              <span class="video-thumb-icon">🌺</span>
              <div class="video-play-btn">▶</div>
            </div>
            <div class="video-card-body">
              <h4>Cultura Maya en Cancún</h4>
              <p>Descubre las tradiciones mayas del estado de Quintana Roo y la Península de Yucatán.</p>
            </div>
          </a>
          <a class="video-card" href="https://www.youtube.com/results?search_query=numeros+maya+yucateco+aprende" target="_blank" rel="noopener" style="text-decoration:none">
            <div class="video-thumb" style="background:linear-gradient(135deg,#00C9A7,#4ECDC4)">
              <span class="video-thumb-icon">🔢</span>
              <div class="video-play-btn">▶</div>
            </div>
            <div class="video-card-body">
              <h4>Números en Maya Yucateco</h4>
              <p>Aprende a contar del 1 al 20 en maya yucateco con el sistema vigesimal ancestral.</p>
            </div>
          </a>
        </div>

        <!-- Quiz section -->
        <div style="text-align:center; margin:2rem 0 2.5rem">
          <div class="section-label sl-sun fade-in" style="justify-content:center; margin-bottom:.5rem">Mini Quiz</div>
          <h2 class="section-title fade-in" style="text-align:center">¿Cuánto has <em>aprendido</em>? 🧠</h2>
          <p class="section-sub fade-in" style="margin:0 auto; text-align:center">Pon a prueba tu vocabulario maya yucateco</p>
        </div>
        <div class="maya-quiz-wrapper fade-in" id="mayaQuizWrapper">
          <div class="mq-header">
            <div class="mq-progress-wrap">
              <div id="mqCounter" style="font-size:.78rem;font-weight:700;color:var(--text-light);margin-bottom:.3rem">Pregunta 1 / 10</div>
              <div class="mq-progress-bar"><div class="mq-progress-fill" id="mqFill"></div></div>
            </div>
            <div class="mq-score" id="mqScore">0 ⭐</div>
          </div>
          <div id="mqQuestionArea" style="display:none">
            <div class="mq-question" id="mqWord"></div>
            <div class="mq-hint" id="mqHint"></div>
            <div class="mq-choices" id="mqChoices"></div>
            <div class="mq-feedback" id="mqFeedback"></div>
            <button class="mq-next-btn" id="mqNextBtn" onclick="nextQuizQ()" style="display:none">Siguiente →</button>
          </div>
          <div id="mqComplete" style="display:none" class="mq-complete">
            <span class="mq-complete-emoji" id="mqCompleteEmoji">🎉</span>
            <div class="mq-final-score" id="mqFinalScore"></div>
            <p style="color:var(--text-light);margin-top:.5rem" id="mqFinalMsg"></p>
            <button class="mq-restart-btn" onclick="startMayaQuiz()">Jugar de nuevo 🔄</button>
          </div>
          <div id="mqStart" style="text-align:center;padding:1rem 0">
            <p style="color:var(--text-light);margin-bottom:1.5rem;font-size:.95rem">¡Practica las palabras que aprendiste! Se elegirán 10 palabras al azar.</p>
            <button class="btn-wa" onclick="startMayaQuiz()" style="background:linear-gradient(135deg,var(--sun),#E8A000);box-shadow:0 6px 20px rgba(255,184,0,.4);border:none;cursor:pointer;color:white;font-family:'Nunito',sans-serif;font-weight:700;font-size:1rem;padding:.75rem 2rem;border-radius:50px;">
              🎮 Iniciar Quiz Maya
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- MISIÓN Y VISIÓN -->
    <section style="background: #f8faf9;" class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800">Misión y Visión</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="reveal-card rounded-3xl p-8 shadow-sm"
            style="background: linear-gradient(135deg, #f0fdf9, #e0faf4); border: 1px solid rgba(0,184,160,0.15);">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl mb-5" style="background: rgba(0,184,160,0.15);">&#x1F3AF;</div>
            <h3 class="text-xl font-extrabold mb-3" style="color: #00b8a0;">Misión</h3>
            <p class="text-slate-600 leading-relaxed text-sm">Brindar un entorno seguro, afectuoso y estimulante donde cada niño pueda desarrollar sus capacidades cognitivas, emocionales y físicas. Somos el apoyo fundamental de las familias trabajadoras de Cancún.</p>
          </div>
          <div class="reveal-card rounded-3xl p-8 shadow-sm"
            style="background: linear-gradient(135deg, #f0f4ff, #e8edfa); border: 1px solid rgba(69,123,157,0.15);">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl mb-5" style="background: rgba(69,123,157,0.12);">&#x1F52D;</div>
            <h3 class="text-xl font-extrabold mb-3 text-slate-700">Visión</h3>
            <p class="text-slate-600 leading-relaxed text-sm">Consolidarnos como la estancia infantil líder en la Región 91, reconocidos por nuestra excelencia educativa, calidez humana e innovación constante en técnicas de estimulación temprana.</p>
          </div>
        </div>
      </div>
