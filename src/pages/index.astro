---
import Layout from '../layouts/Layout.astro';
import ColorGame from '../components/ColorGame.tsx';
import BubbleGame from '../components/BubbleGame.tsx';
---

<Layout title="Estancia Infantil Mis Pekes | Cancún">

  <!-- ── WHATSAPP FLOATING BUTTON ── -->
  <a
    href="https://wa.me/5219982415799"
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-2xl transition-transform hover:scale-110 flex items-center justify-center"
    aria-label="Contactar por WhatsApp"
  >
    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.857L.057 23.882a.75.75 0 0 0 .918.919l6.105-1.474A11.942 11.942 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.717 9.717 0 0 1-4.964-1.36l-.356-.213-3.683.889.909-3.594-.233-.37A9.718 9.718 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
    </svg>
  </a>

  <!-- ── NAVBAR ── -->
  <nav class="bg-white border-b border-slate-100 sticky top-0 z-40 shadow-sm">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="flex items-center gap-2 text-xl font-extrabold text-slate-800 no-underline">
        <span class="text-pekes-primary">Mis Pekes</span>
        <span aria-hidden="true">🌻</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="#faq" class="text-slate-500 hover:text-pekes-primary text-sm font-semibold transition-colors hidden sm:block">Inscripciones</a>
        <a href="#footer" class="text-slate-500 hover:text-pekes-primary text-sm font-semibold transition-colors hidden sm:block">Ubicación</a>
        <a
          href="https://wa.me/5219982415799"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-green-500 hover:bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-full transition-colors"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <header
    class="relative overflow-hidden text-white text-center"
    style="background: linear-gradient(135deg, #00d4b8 0%, #00b8a0 50%, #1a4d47 100%); padding: 5rem 1.5rem 6rem;"
  >
    <!-- Decorative blobs -->
    <div class="absolute top-[-50px] right-[-100px] w-72 h-72 rounded-full" style="background: rgba(255,255,255,0.05);"></div>
    <div class="absolute bottom-[-80px] left-[-120px] w-64 h-64 rounded-full" style="background: rgba(255,255,255,0.05);"></div>

    <div class="max-w-2xl mx-auto relative z-10">
      <p class="inline-block bg-white/20 border border-white/30 text-white text-xs font-bold uppercase tracking-widest px-4 py-1 rounded-full mb-6">
        ✨ Cancún · Región 91
      </p>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4">
        Estancia Infantil
        <br />
        <span class="text-5xl md:text-6xl" style="background: linear-gradient(135deg, #fff 0%, #e8f5f2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Mis Pekes
        </span>
      </h1>
      <p class="text-xl font-semibold mb-3 opacity-95">"Creamos, Aprendemos y Crecemos Cada Día" 🌱</p>
      <p class="text-sm leading-relaxed mb-8 opacity-85 max-w-lg mx-auto">
        En Mis Pekes, cada niño es un pekeño universo de posibilidades. Ofrecemos cuidado seguro, afectuoso y estimulante para bebés y preescolares en el corazón de Cancún.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="https://wa.me/5219982415799"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white font-semibold text-sm px-7 py-3 rounded-full transition-transform hover:scale-105 hover:shadow-lg"
          style="color: #00b8a0;"
        >
          Inscripciones Abiertas
        </a>
        <a
          href="#juegos"
          class="bg-transparent border-2 border-white text-white font-semibold text-sm px-7 py-3 rounded-full transition-transform hover:scale-105"
        >
          Juegos Educativos
        </a>
      </div>
    </div>
  </header>

  <!-- ── QUICK INFO BAR ── -->
  <div style="background: #1a4d47;" class="py-6 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4">
        <span class="text-2xl" aria-hidden="true">🕐</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Horario</p>
          <p class="text-white text-sm font-bold mt-0.5">Lun–Vie · 7:00 AM – 5:00 PM</p>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4">
        <span class="text-2xl" aria-hidden="true">👶</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Edades</p>
          <p class="text-white text-sm font-bold mt-0.5">43 días – 6 años</p>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-white/10 border border-white/10 rounded-2xl px-5 py-4">
        <span class="text-2xl" aria-hidden="true">📍</span>
        <div>
          <p class="text-white/60 text-xs font-bold uppercase tracking-wider">Ubicación</p>
          <p class="text-white text-sm font-bold mt-0.5">Región 91, Cancún Q.R.</p>
        </div>
      </div>
    </div>
  </div>

  <main>

    <!-- ── VALORES ── -->
    <section id="nosotros" class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-extrabold text-center text-slate-800 mb-12">Nuestra Filosofía de Cuidado</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:-translate-y-1 transition-transform">
          <span class="text-4xl" aria-hidden="true">🔒</span>
          <h3 class="text-lg font-bold mt-4 mb-2" style="color: #00b8a0;">Seguridad</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Bienestar integral. Espacios seguros, personal capacitado y protocolos de salud rigurosos.</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:-translate-y-1 transition-transform">
          <span class="text-4xl" aria-hidden="true">💚</span>
          <h3 class="text-lg font-bold mt-4 mb-2" style="color: #00b8a0;">Confianza</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Comunicación transparente con padres. Reportes diarios y acceso a nuestros espacios.</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:-translate-y-1 transition-transform">
          <span class="text-4xl" aria-hidden="true">🫶</span>
          <h3 class="text-lg font-bold mt-4 mb-2" style="color: #00b8a0;">Empatía</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Atención personalizada. Respetamos el ritmo y necesidades particulares de cada niño.</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:-translate-y-1 transition-transform">
          <span class="text-4xl" aria-hidden="true">🌟</span>
          <h3 class="text-lg font-bold mt-4 mb-2" style="color: #00b8a0;">Compromiso</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Desarrollo integral. Estimulación temprana con metodologías educativas comprobadas.</p>
        </div>
      </div>
    </section>

    <!-- ── SERVICIOS ── -->
    <section id="servicios" class="bg-white py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-extrabold text-center text-slate-800 mb-12">Nuestros Servicios</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Nutrición -->
          <div class="bg-pekes-cream rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-1 transition-transform">
            <div class="h-28 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #ffd6a5, #ffb88c);">🍽️</div>
            <div class="p-5">
              <h3 class="font-bold text-base mb-2" style="color: #ff8c42;">Nutrición Balanceada</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Menús diseñados por nutricionista. Respetamos alergias y preferencias dietéticas con recetas caseras.</p>
            </div>
          </div>
          <!-- Educativo -->
          <div class="bg-pekes-cream rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-1 transition-transform">
            <div class="h-28 flex items-center justify-center text-5xl text-white" style="background: linear-gradient(135deg, #a8dadc, #457b9d);">📚</div>
            <div class="p-5">
              <h3 class="font-bold text-base mb-2" style="color: #457b9d;">Programa Educativo</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Estimulación temprana estructurada. Desarrollo de lenguaje, motricidad y habilidades cognitivas.</p>
            </div>
          </div>
          <!-- Actividad Física -->
          <div class="bg-pekes-cream rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-1 transition-transform">
            <div class="h-28 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #c1ffa9, #7bc043);">⚽</div>
            <div class="p-5">
              <h3 class="font-bold text-base mb-2" style="color: #7bc043;">Actividad Física</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Juego libre y actividades psicomotrices. Espacios seguros para correr, trepar y explorar.</p>
            </div>
          </div>
          <!-- Expresión Creativa -->
          <div class="bg-pekes-cream rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:-translate-y-1 transition-transform">
            <div class="h-28 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #ffc6ff, #ff6ec7);">🎨</div>
            <div class="p-5">
              <h3 class="font-bold text-base mb-2" style="color: #ff6ec7;">Expresión Creativa</h3>
              <p class="text-slate-500 text-sm leading-relaxed">Arte, música y expresión. Fomentamos la creatividad sin límites en un ambiente seguro.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── ZONA INTERACTIVA ── -->
    <section id="juegos" class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-slate-800 mb-3">Zona de Aprendizaje Interactivo</h2>
        <p class="text-slate-500 text-sm max-w-md mx-auto">Minijuegos educativos que estimulan el desarrollo cognitivo y motor</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <div class="flex items-center gap-3 mb-3 px-1">
            <span class="text-3xl" aria-hidden="true">🫧</span>
            <div>
              <h3 class="font-bold text-slate-800">Atrapa Burbujas</h3>
              <p class="text-slate-500 text-xs">Coordinación motriz y velocidad visual</p>
            </div>
          </div>
          <BubbleGame client:visible />
        </div>
        <div>
          <div class="flex items-center gap-3 mb-3 px-1">
            <span class="text-3xl" aria-hidden="true">🌈</span>
            <div>
              <h3 class="font-bold text-slate-800">Aprende Colores</h3>
              <p class="text-slate-500 text-xs">Reconocimiento visual y asociación cognitiva</p>
            </div>
          </div>
          <ColorGame client:visible />
        </div>
      </div>
    </section>

    <!-- ── MISIÓN Y VISIÓN ── -->
    <section class="bg-white py-20 px-6">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10">
        <div class="rounded-2xl border border-slate-100 shadow-sm p-8" style="background: linear-gradient(135deg, #f0fdf9, #e6faf6);">
          <h3 class="text-xl font-extrabold mb-3" style="color: #00b8a0;">Misión</h3>
          <p class="text-slate-600 leading-relaxed text-sm">Brindar un entorno seguro, afectuoso y estimulante donde cada niño pueda desarrollar sus capacidades cognitivas, emocionales y físicas. Somos el apoyo fundamental de las familias trabajadoras de Cancún.</p>
        </div>
        <div class="rounded-2xl border border-slate-100 shadow-sm p-8" style="background: linear-gradient(135deg, #f0f4ff, #e8edfa);">
          <h3 class="text-xl font-extrabold mb-3 text-slate-700">Visión</h3>
          <p class="text-slate-600 leading-relaxed text-sm">Consolidarnos como la estancia infantil líder en la Región 91, reconocidos por nuestra excelencia educativa, calidez humana e innovación constante en técnicas de estimulación temprana.</p>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section id="faq" class="py-20 px-6" style="background: #f8faf9;">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-extrabold text-center text-slate-800 mb-10">Preguntas Frecuentes</h2>
        <div class="space-y-3">
          <details class="bg-white border border-slate-100 rounded-2xl shadow-sm px-6 py-5 cursor-pointer group">
            <summary class="font-bold text-slate-800 select-none list-none flex justify-between items-center">
              ¿Cuáles son los requisitos de inscripción?
              <span class="text-pekes-primary text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-slate-500 text-sm leading-relaxed">Se requiere: Acta de nacimiento, cartilla de vacunación actualizada, comprobante de domicilio, datos de contacto de emergencia y datos médicos relevantes (alergias, medicamentos).</p>
          </details>
          <details class="bg-white border border-slate-100 rounded-2xl shadow-sm px-6 py-5 cursor-pointer group">
            <summary class="font-bold text-slate-800 select-none list-none flex justify-between items-center">
              ¿Qué edades atienden?
              <span class="text-pekes-primary text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-slate-500 text-sm leading-relaxed">Recibimos niños desde 43 días de nacidos (lactantes) hasta 6 años (preescolar). Contamos con aulas separadas por etapa de desarrollo.</p>
          </details>
          <details class="bg-white border border-slate-100 rounded-2xl shadow-sm px-6 py-5 cursor-pointer group">
            <summary class="font-bold text-slate-800 select-none list-none flex justify-between items-center">
              ¿Cuál es el horario de atención?
              <span class="text-pekes-primary text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-slate-500 text-sm leading-relaxed">Lunes a viernes, 7:00 AM a 5:00 PM. Contamos con servicios de horario extendido previa solicitud.</p>
          </details>
          <details class="bg-white border border-slate-100 rounded-2xl shadow-sm px-6 py-5 cursor-pointer group">
            <summary class="font-bold text-slate-800 select-none list-none flex justify-between items-center">
              ¿Cómo es la comunicación con los padres?
              <span class="text-pekes-primary text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-slate-500 text-sm leading-relaxed">Reportes diarios vía WhatsApp y fotos de las actividades. Reuniones mensuales con cuidadores y boletín educativo trimestral.</p>
          </details>
        </div>
      </div>
    </section>

  </main>

  <!-- ── FOOTER ── -->
  <footer id="footer" style="background: #1a4d47;" class="text-white py-14 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid sm:grid-cols-3 gap-8 mb-10 text-sm">
        <div>
          <h4 class="font-bold text-base mb-4">Contacto</h4>
          <p class="opacity-80 mb-2">📞 +52 998 241 5799</p>
          <p class="opacity-70 leading-relaxed">Lunes a Viernes<br>7:00 AM – 5:00 PM</p>
        </div>
        <div>
          <h4 class="font-bold text-base mb-4">Ubicación</h4>
          <p class="opacity-70 leading-relaxed">Región 91, Manzana 48, Lote 8<br>Calle 38 Pte., C.P. 77516<br>Cancún, Quintana Roo</p>
        </div>
        <div>
          <h4 class="font-bold text-base mb-4">Síguenos</h4>
          <a href="https://www.facebook.com/p/Estancia-Infantil-MIS-PEKES-100063553933907/" target="_blank" rel="noopener noreferrer" class="block opacity-80 hover:opacity-100 transition-opacity mb-2">
            👍 Facebook Oficial
          </a>
          <a href="https://wa.me/5219982415799" target="_blank" rel="noopener noreferrer" class="block opacity-80 hover:opacity-100 transition-opacity">
            💬 WhatsApp Directo
          </a>
        </div>
      </div>
      <div class="border-t pt-8 text-center" style="border-color: rgba(255,255,255,0.15);">
        <p class="text-xs opacity-60">© 2026 Estancia Infantil "Mis Pekes". Todos los derechos reservados.</p>
        <p class="text-xs mt-1 opacity-50">Construido con Astro + SolidJS · Optimizado para máximo rendimiento</p>
      </div>
    </div>
  </footer>

</Layout>
