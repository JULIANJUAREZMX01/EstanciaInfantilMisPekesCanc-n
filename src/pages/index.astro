            <p class="text-xs font-semibold" style="color:#00b8a0;">$450</p>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all text-center">
            <div class="text-4xl mb-3">&#x1F9FB;</div>
            <h4 class="font-bold text-slate-800 text-sm mb-1">Toallitas</h4>
            <p class="text-xs font-semibold" style="color:#00b8a0;">$60</p>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all text-center">
            <div class="text-4xl mb-3">&#x1F455;</div>
            <h4 class="font-bold text-slate-800 text-sm mb-1">Ropa de Emergencia</h4>
