      background: var(--cream); border: none; border-radius: 50%;
      width: 28px; height: 28px; cursor: pointer; font-size: .85rem;
      display: flex; align-items: center; justify-content: center; transition: all .2s; line-height: 1;
    }
    .maya-speak-btn:hover { background: var(--sun); transform: scale(1.15); }
    /* Videos */
    .video-cards-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem; margin-bottom: 3rem;
    }
    .video-card {
      background: white; border-radius: 20px; overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,.07); transition: all .3s;
    }
    .video-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.1); }
    .video-thumb {
      aspect-ratio: 16/9; display: flex; flex-direction: column; align-items: center;
      justify-content: center; position: relative; cursor: pointer;
    }
    .video-thumb-icon { font-size: 3rem; margin-bottom: .5rem; }
    .video-play-btn {
      position: absolute; width: 54px; height: 54px; background: rgba(0,0,0,.55);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; color: white; transition: all .3s;
    }
    .video-thumb:hover .video-play-btn { background: var(--coral); transform: scale(1.1); }
    .video-card-body { padding: 1rem 1.2rem; }
    .video-card-body h4 { font-size: .95rem; font-weight: 700; color: var(--deep); margin-bottom: .3rem; }
    .video-card-body p { font-size: .8rem; color: var(--text-light); line-height: 1.5; }
    /* Quiz */
    .maya-quiz-wrapper {
      background: white; border-radius: 28px; padding: 2.5rem;
      max-width: 560px; margin: 0 auto; box-shadow: 0 8px 32px rgba(0,0,0,.08);
    }
    .mq-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap;
    }
    .mq-progress-wrap { flex: 1; min-width: 150px; }
    .mq-progress-bar { height: 8px; background: #E8EDF5; border-radius: 50px; overflow: hidden; }
    .mq-progress-fill {
      height: 100%; background: linear-gradient(90deg, var(--teal), var(--sun));
      border-radius: 50px; width: 0%; transition: width .4s;
    }
    .mq-score {
      font-family: 'Baloo 2', cursive; font-size: 1.3rem; font-weight: 800;
      color: var(--coral); background: var(--cream); padding: .25rem .9rem; border-radius: 12px;
    }
    .mq-question {
      font-family: 'Baloo 2', cursive; font-size: 2.2rem; font-weight: 800;
      color: var(--deep); text-align: center; margin-bottom: .4rem;
    }
    .mq-hint {
      text-align: center; font-size: .85rem; color: var(--text-light); margin-bottom: 1.8rem;
    }
    .mq-choices {
      display: grid; grid-template-columns: 1fr 1fr; gap: .8rem; margin-bottom: 1.2rem;
    }
    .mq-choice {
      background: var(--cream); border: 2px solid #E8EDF5; border-radius: 14px;
      padding: .85rem; font-family: 'Nunito', sans-serif; font-weight: 700;
      font-size: .9rem; color: var(--deep); cursor: pointer; transition: all .2s; text-align: center;
    }
    .mq-choice:hover:not(:disabled) { border-color: var(--teal); background: #E0FBF5; transform: scale(1.02); }
    .mq-choice.correct { background: #E0FBF5 !important; border-color: var(--teal) !important; color: var(--teal-dark) !important; }
    .mq-choice.wrong { background: #FFE8E8 !important; border-color: var(--coral) !important; color: var(--coral) !important; }
    .mq-choice:disabled { cursor: default; }
    .mq-feedback { text-align: center; font-weight: 700; font-size: 1rem; min-height: 28px; margin-bottom: .5rem; }
    .mq-next-btn {
      display: block; width: 100%; background: linear-gradient(135deg, var(--deep), #2a5a8a);
      color: white; border: none; border-radius: 50px; padding: .8rem;
      font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 1rem;
      cursor: pointer; transition: all .25s; box-shadow: 0 4px 16px rgba(26,60,94,.3);
      margin-top: .8rem;
    }
    .mq-next-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,60,94,.4); }
    .mq-complete { text-align: center; padding: 1.5rem 0; }
    .mq-complete-emoji { font-size: 4rem; display: block; margin-bottom: .8rem; }
    .mq-final-score {
      font-family: 'Baloo 2', cursive; font-size: 3rem; font-weight: 800; color: var(--coral);
    }
    .mq-restart-btn {
      background: linear-gradient(135deg, var(--coral), var(--coral-light));
      color: white; border: none; border-radius: 50px; padding: .75rem 2rem;
      font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 1rem;
      cursor: pointer; box-shadow: 0 6px 20px rgba(255,107,107,.4);
      transition: all .3s; margin-top: 1.5rem;
    }
    .mq-restart-btn:hover { transform: translateY(-2px); }
    /* Confetti */
    #confetti-container {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 9999; overflow: hidden;
    }
    .confetti-piece {
      position: absolute; opacity: 0;
      animation: confettiFall linear forwards;
    }
    @keyframes confettiFall {
      0% { opacity: 1; transform: translateY(-20px) rotate(0deg) scale(1); }
      100% { opacity: 0; transform: translateY(100vh) rotate(720deg) scale(.5); }
    }
    @media (max-width: 900px) {
      .maya-dict-grid { grid-template-columns: repeat(2, 1fr); }
      .mq-choices { grid-template-columns: 1fr; }
      .cg-colors { grid-template-columns: repeat(2, 1fr); }
      .game-panel { padding: 1.2rem; }
    }
    @media (max-width: 580px) {
      section { padding: 60px 5%; }
      .maya-dict-grid { grid-template-columns: repeat(2, 1fr); }
      .game-topbar { flex-direction: column; align-items: flex-start; gap: .4rem; }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes floatBubble {
      0%   { transform: translateY(0) scale(1);      opacity: 0.15; }
      50%  { transform: translateY(-40px) scale(1.05); opacity: 0.25; }
      100% { transform: translateY(0) scale(1);      opacity: 0.15; }
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(1); }
      50%       { opacity: 0.8; transform: scale(1.4); }
    }
    @keyframes scrollDot {
      0%   { transform: translateY(0);    opacity: 1; }
      80%  { transform: translateY(10px); opacity: 0; }
      100% { transform: translateY(0);    opacity: 0; }
    }

    .animate-fade-in        { animation: fadeIn 0.8s ease both; }
    .animate-fade-in-delay  { animation: fadeIn 1s ease 0.3s both; }
    .animate-fade-in-delay2 { animation: fadeIn 1s ease 0.5s both; }
    .animate-slide-up       { animation: slideUp 0.9s ease 0.1s both; }

    .hero-bubbles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
    .bubble {
      position: absolute;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      animation: floatBubble linear infinite;
    }
    .bubble-1 { width:180px; height:180px; top:5%;  left:8%;  animation-duration:7s;  animation-delay:0s; }
    .bubble-2 { width:110px; height:110px; top:60%; left:80%; animation-duration:9s;  animation-delay:1s; }
    .bubble-3 { width:80px;  height:80px;  top:20%; left:70%; animation-duration:6s;  animation-delay:2s; }
    .bubble-4 { width:60px;  height:60px;  top:75%; left:15%; animation-duration:8s;  animation-delay:0.5s; }
    .bubble-5 { width:140px; height:140px; top:40%; left:45%; animation-duration:11s; animation-delay:3s; }
    .bubble-6 { width:50px;  height:50px;  top:10%; left:50%; animation-duration:5s;  animation-delay:1.5s; }
    .star {
      position: absolute;
      font-size: 20px;
      color: rgba(255,255,255,0.5);
      animation: twinkle ease-in-out infinite;
    }
    .star-1 { top:15%; left:20%; animation-duration:3s;   animation-delay:0s; }
    .star-2 { top:70%; left:60%; animation-duration:4s;   animation-delay:1s;   font-size:14px; }
    .star-3 { top:30%; left:88%; animation-duration:2.5s; animation-delay:0.8s; font-size:18px; }

    .scroll-dot { animation: scrollDot 1.6s ease-in-out infinite; }

    .reveal-card {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    #scroll-top-btn.show {
      opacity: 1;
      pointer-events: auto;
    }
  </style>

  <script>
    // ── Reveal cards (existing) ──
    const revealObserver = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("visible"); }),
      { threshold: 0.12 }
    );
    document.querySelectorAll(".reveal-card").forEach((el) => revealObserver.observe(el));

    // ── Scroll-to-top button ──
    const btn = document.getElementById("scroll-top-btn");
    window.addEventListener("scroll", () => {
      if (btn) btn.classList.toggle("show", window.scrollY > 400);
    }, { passive: true });

    // ── Fade-in observer ──
    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), 60 * i);
          fadeObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(el => fadeObserver.observe(el));

    // ══ GAME TAB SWITCHER ══
    function switchGame(name: string, btn: HTMLElement) {
      document.querySelectorAll('.game-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.game-tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('game-' + name)!.classList.add('active');
      btn.classList.add('active');
    }
    (window as any).switchGame = switchGame;

    // ══ BUBBLE GAME ══
    let bubbleGameActive = false;
    let bubbles: any[] = [];
    let bubbleScore = 0;
    let bubbleTimeLeft = 30;
    let bubbleIntervals: number[] = [];
    let bubbleAnimFrame: number | null = null;

    function startBubbleGame() {
      bubbles = [];
      bubbleScore = 0;
      bubbleTimeLeft = 30;
      bubbleGameActive = true;
      bubbleIntervals.forEach(clearInterval);
      bubbleIntervals = [];
      if (bubbleAnimFrame) cancelAnimationFrame(bubbleAnimFrame);

      const scoreEl = document.getElementById('bubbleScore');
      const timerEl = document.getElementById('bubbleTimer');
      const bubbleBtn = document.getElementById('bubbleBtn') as HTMLButtonElement;
      if (scoreEl) scoreEl.textContent = '🫧 0 puntos';
      if (timerEl) timerEl.textContent = '⏱ 30s';
      if (bubbleBtn) bubbleBtn.style.display = 'none';

      const canvas = document.getElementById('bubbleCanvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      canvas.onmousedown = (e) => {
        const r = canvas.getBoundingClientRect();
        popBubbleAt((e.clientX - r.left) * (canvas.width / r.width), (e.clientY - r.top) * (canvas.height / r.height));
      };
      canvas.ontouchstart = (e) => {
        e.preventDefault();
        const r = canvas.getBoundingClientRect();
        const t = e.touches[0];
        popBubbleAt((t.clientX - r.left) * (canvas.width / r.width), (t.clientY - r.top) * (canvas.height / r.height));
      };

      const spawnId = window.setInterval(() => {
        if (!bubbleGameActive) { clearInterval(spawnId); return; }
        if (bubbles.length < 14) spawnBubble(canvas.width, canvas.height);
      }, 700);
      bubbleIntervals.push(spawnId);

      const timerId = window.setInterval(() => {
        bubbleTimeLeft--;
        if (timerEl) timerEl.textContent = '⏱ ' + bubbleTimeLeft + 's';
        if (bubbleTimeLeft <= 0) {
          clearInterval(timerId);
          clearInterval(spawnId);
          bubbleGameActive = false;
          finishBubbleGame();
        }
      }, 1000);
      bubbleIntervals.push(timerId);

      (function loop() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        bubbles = bubbles.filter(b => {
          b.y -= b.speed;
          b.x += Math.sin(b.wobble += .05) * .9;
          if (b.popping) { b.popR += 4; b.alpha -= .09; }
          if (b.alpha <= 0 || b.y + b.r < -10) return false;
          ctx.save();
          ctx.globalAlpha = b.alpha;
          const g = ctx.createRadialGradient(b.x - b.r * .3, b.y - b.r * .3, b.r * .1, b.x, b.y, b.r);
          g.addColorStop(0, 'rgba(255,255,255,.72)');
          g.addColorStop(.5, b.color + '88');
          g.addColorStop(1, b.color + 'cc');
          ctx.beginPath();
          ctx.arc(b.x, b.y, b.popping ? b.popR : b.r, 0, Math.PI * 2);
          ctx.fillStyle = g;
          ctx.fill();
          if (!b.popping) {
            ctx.strokeStyle = b.color + '99';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            ctx.font = Math.round(b.r * .9) + 'px serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillStyle = 'rgba(255,255,255,.9)';
            ctx.fillText(b.emoji, b.x, b.y);
          }
          ctx.restore();
          return true;
        });
        bubbleAnimFrame = requestAnimationFrame(loop);
      })();
    }
    (window as any).startBubbleGame = startBubbleGame;

    function spawnBubble(w: number, h: number) {
      const colors = ['#FF6B6B','#FFB800','#00C9A7','#4ECDC4','#C9B8FF','#FF8E8E','#7BC043'];
      const emojis = ['⭐','🌟','🎈','🌸','🍎','🦋','🌈','💛','🎵','🫧','🏵️','🍀'];
      const r = 24 + Math.random() * 22;
      bubbles.push({
        x: r + Math.random() * (w - 2 * r), y: h + r, r,
        speed: .7 + Math.random() * 1.3,
        wobble: Math.random() * Math.PI * 2,
        color: colors[Math.floor(Math.random() * colors.length)],
        emoji: emojis[Math.floor(Math.random() * emojis.length)],
        alpha: 1, popping: false, popR: 0
      });
    }

    function popBubbleAt(x: number, y: number) {
      for (let i = bubbles.length - 1; i >= 0; i--) {
        const b = bubbles[i];
        if (!b.popping && Math.hypot(x - b.x, y - b.y) < b.r) {
          b.popping = true; b.popR = b.r;
          bubbleScore++;
          const scoreEl = document.getElementById('bubbleScore');
          if (scoreEl) scoreEl.textContent = '🫧 ' + bubbleScore + ' punto' + (bubbleScore === 1 ? '' : 's');
          playPop();
          break;
        }
      }
    }

    function finishBubbleGame() {
      const bubbleBtn = document.getElementById('bubbleBtn') as HTMLButtonElement;
      if (!bubbleBtn) return;
      bubbleBtn.style.display = 'block';
      if (bubbleScore >= 20) { bubbleBtn.textContent = '🏆 ¡Increíble! ' + bubbleScore + ' pts · Jugar de nuevo'; launchConfetti(); }
      else if (bubbleScore >= 10) { bubbleBtn.textContent = '⭐ ¡Bien! ' + bubbleScore + ' pts · Jugar de nuevo'; }
      else { bubbleBtn.textContent = '🔄 ' + bubbleScore + ' pts · ¡Inténtalo otra vez!'; }
    }

    // ══ COLOR GAME ══
    const colorsData = [
      { maya: 'Chak',          spanish: 'Rojo',      hex: '#E63946' },
      { maya: "K'an",          spanish: 'Amarillo',   hex: '#FFB800' },
      { maya: 'Yax',           spanish: 'Verde',      hex: '#2DC653' },
      { maya: "Ek'",           spanish: 'Negro',      hex: '#1A1A2E' },
      { maya: 'Sak',           spanish: 'Blanco',     hex: '#F0F0F0' },
      { maya: "Yax k'áak'nab", spanish: 'Azul',       hex: '#4ECDC4' },
    ];
    let cgActive = false, cgScore = 0, cgTotal = 0;

    function startColorGame() {
      cgScore = 0; cgTotal = 0; cgActive = true;
      const cgBtn = document.getElementById('cgBtn') as HTMLButtonElement;
      const cgScoreEl = document.getElementById('cgScore');
      if (cgBtn) cgBtn.style.display = 'none';
      if (cgScoreEl) cgScoreEl.textContent = '';
      renderColorQ();
    }
    (window as any).startColorGame = startColorGame;

    function renderColorQ() {
      const ans = colorsData[Math.floor(Math.random() * colorsData.length)];
      const cgWordEl = document.getElementById('cgWord');
      const cgMayaEl = document.getElementById('cgMaya');
      if (cgWordEl) cgWordEl.textContent = ans.spanish;
      if (cgMayaEl) cgMayaEl.textContent = 'En maya yucateco: "' + ans.maya + '"';
      let opts = [ans];
      const others = colorsData.filter(c => c !== ans);
      while (opts.length < colorsData.length) {
        const r = others[Math.floor(Math.random() * others.length)];
        if (!opts.includes(r)) opts.push(r);
      }
      opts = opts.sort(() => Math.random() - .5);
      const grid = document.getElementById('cgGrid');
      if (!grid) return;
      grid.innerHTML = '';
      opts.forEach(c => {
        const b = document.createElement('button');
        b.className = 'cg-color-btn';
        b.dataset.hex = c.hex;
        b.style.cssText = 'background:' + c.hex + ';' + (c.hex === '#F0F0F0' ? 'border:2px solid #ccc;' : '');
        b.onclick = () => checkColorQ(b, c, ans);
        grid.appendChild(b);
      });
    }

    function checkColorQ(btn: HTMLButtonElement, chosen: typeof colorsData[0], answer: typeof colorsData[0]) {
      if (!cgActive) return;
      cgTotal++;
      document.querySelectorAll('.cg-color-btn').forEach((b: any) => { b.onclick = null; });
      const cgScoreEl = document.getElementById('cgScore');
      if (chosen === answer) {
        btn.classList.add('correct');
        cgScore++;
        if (cgScoreEl) cgScoreEl.textContent = '✅ ¡Correcto! "' + answer.maya + '" = ' + answer.spanish + '  (' + cgScore + '/' + cgTotal + ')';
        playSuccess();
      } else {
        btn.classList.add('wrong');
        document.querySelectorAll('.cg-color-btn').forEach((b: any) => {
          if (b.dataset.hex === answer.hex) b.classList.add('correct');
        });
        if (cgScoreEl) cgScoreEl.textContent = '❌ Era "' + answer.maya + '" = ' + answer.spanish + '  (' + cgScore + '/' + cgTotal + ')';
      }
      setTimeout(() => {
        if (cgTotal >= 10) {
          if (cgScoreEl) cgScoreEl.textContent = '🎉 ¡Completado! ' + cgScore + '/10 correctas';
          const cgBtn = document.getElementById('cgBtn') as HTMLButtonElement;
          if (cgBtn) { cgBtn.textContent = '🔄 Jugar de nuevo'; cgBtn.style.display = 'block'; }
          cgActive = false;
          if (cgScore >= 8) launchConfetti();
        } else {
          renderColorQ();
        }
      }, 1500);
    }

    // ══ WEB AUDIO SOUNDS ══
    let audioCtx: AudioContext | null = null;
    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return audioCtx;
    }
    function playPop() {
      try {
        const ctx = getCtx();
        const osc = ctx.createOscillator(), g = ctx.createGain();
        osc.connect(g); g.connect(ctx.destination);
        osc.frequency.setValueAtTime(700, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(180, ctx.currentTime + .16);
        g.gain.setValueAtTime(.18, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(.001, ctx.currentTime + .22);
        osc.start(); osc.stop(ctx.currentTime + .22);
      } catch (e) {}
    }
    function playSuccess() {
      try {
        const ctx = getCtx();
        [523, 659, 784, 1047].forEach((freq, i) => {
          const osc = ctx.createOscillator(), g = ctx.createGain();
          osc.connect(g); g.connect(ctx.destination);
          osc.frequency.value = freq; osc.type = 'sine';
          const t = ctx.currentTime + i * .11;
          g.gain.setValueAtTime(.12, t);
          g.gain.exponentialRampToValueAtTime(.001, t + .3);
          osc.start(t); osc.stop(t + .32);
        });
      } catch (e) {}
    }

    // ══ CONFETTI ══
    function launchConfetti() {
      let container = document.getElementById('confetti-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'confetti-container';
        document.body.appendChild(container);
      }
      const colors = ['#FF6B6B','#FFB800','#00C9A7','#4ECDC4','#C9B8FF','#FF8E8E','#ffffff','#2DC653'];
      for (let i = 0; i < 90; i++) {
        const p = document.createElement('div');
        p.className = 'confetti-piece';
        p.style.cssText = `
          left:${Math.random() * 100}%;
          background:${colors[i % colors.length]};
          width:${6 + Math.random() * 8}px;
          height:${8 + Math.random() * 10}px;
          border-radius:${Math.random() > .5 ? '50%' : '2px'};
          animation-duration:${2 + Math.random() * 2.5}s;
          animation-delay:${Math.random() * .6}s;
        `;
        container.appendChild(p);
      }
      setTimeout(() => { if (container) container.innerHTML = ''; }, 5000);
    }

    // ══ MAYA DICTIONARY DATA (55 entries) ══
    const mayaData = [
      // Saludos
      { glyph:'👋', maya:"Ba'ax ka wa'alik?", phonetic:"ba-ash ka wa-a-lik",   spanish:"¿Cómo estás?",            cat:"saludos" },
      { glyph:'😊', maya:"Ki'imak in wóol",   phonetic:"ki-i-mak in wo-ol",    spanish:"Estoy feliz",             cat:"saludos" },
      { glyph:'🙏', maya:"Yuum bo'otik",       phonetic:"yum bo-o-tik",          spanish:"Gracias",                 cat:"saludos" },
      { glyph:'😄', maya:"Mixba'al",           phonetic:"mish-ba-al",            spanish:"De nada",                 cat:"saludos" },
      { glyph:'🤝', maya:"Bix a beel?",        phonetic:"bish a be-el",          spanish:"¿Cómo te va?",           cat:"saludos" },
      { glyph:'✅', maya:"Ma'alob",            phonetic:"ma-a-lob",              spanish:"Bien / Bueno",            cat:"saludos" },
      { glyph:'🚀', maya:"Ko'ox!",             phonetic:"ko-osh",                spanish:"¡Vamos!",                 cat:"saludos" },
