---
import Layout from '../layouts/Layout.astro';
import ColorGame from '../components/ColorGame.tsx';
import BubbleGame from '../components/BubbleGame.tsx';
---

<Layout title="Estancia Infantil Mis Pekes | Cancún">
  <a href="https://wa.me/5219982415799" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-2xl transition-transform hover:scale-110 flex items-center justify-center" aria-label="Contactar por WhatsApp">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
  </a>

  <header class="bg-gradient-to-br from-teal-50 to-blue-50 py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-5xl font-extrabold text-gray-900 mb-6">Estancia Infantil <span class="text-teal-600">"Mis Pekes"</span></h1>
      <p class="text-2xl text-gray-700 mb-8 font-medium">"Creamos, Aprendemos y Crecemos Cada Día"</p>
      <div class="flex justify-center gap-4">
        <a href="#servicios" class="bg-teal-600 text-white px-8 py-3 rounded-full font-bold hover:bg-teal-700 transition">Conocer Más</a>
        <a href="#zona-interactiva" class="bg-white text-teal-600 border-2 border-teal-600 px-8 py-3 rounded-full font-bold hover:bg-teal-50 transition">Juegos Educativos</a>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-16 space-y-20">

    <section id="nosotros" class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Nuestra Filosofía</h2>
        <div class="space-y-6 text-gray-600">
          <div>
            <h3 class="text-xl font-bold text-teal-700 mb-2">Misión</h3>
            <p>Brindar un entorno seguro, afectuoso y estimulante donde cada niño pueda desarrollar sus capacidades cognitivas, emocionales y físicas. Apoyo fundamental de las familias trabajadoras de Cancún.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-teal-700 mb-2">Visión</h3>
            <p>Consolidarnos como la estancia infantil líder en la Región 91 y sus alrededores, reconocidos por nuestra excelencia educativa e innovación en técnicas de estimulación temprana.</p>
          </div>
        </div>
      </div>
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Valores Institucionales</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3"><span class="w-2 h-2 bg-teal-500 rounded-full"></span> <strong>Seguridad:</strong> Bienestar absoluto.</li>
          <li class="flex items-center gap-3"><span class="w-2 h-2 bg-teal-500 rounded-full"></span> <strong>Confianza:</strong> Relaciones transparentes.</li>
          <li class="flex items-center gap-3"><span class="w-2 h-2 bg-teal-500 rounded-full"></span> <strong>Empatía:</strong> Atención individualizada.</li>
          <li class="flex items-center gap-3"><span class="w-2 h-2 bg-teal-500 rounded-full"></span> <strong>Compromiso:</strong> Desarrollo integral.</li>
        </ul>
      </div>
    </section>

    <section id="zona-interactiva" class="bg-slate-50 p-8 rounded-3xl border border-slate-200">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Zona Interactiva</h2>
        <p class="text-gray-600">Minijuegos diseñados para la estimulación temprana y el desarrollo psicomotriz.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <BubbleGame client:visible />
        <ColorGame client:visible />
      </div>
    </section>

    <section id="faq" class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-10">Preguntas Frecuentes</h2>
      <div class="space-y-4">
        <details class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 cursor-pointer">
          <summary class="font-bold text-lg text-gray-800">¿Cuáles son los requisitos de inscripción?</summary>
          <p class="mt-4 text-gray-600">Se requiere: Acta de nacimiento, cartilla de vacunación actualizada, comprobante de domicilio y datos de contacto de emergencia.</p>
        </details>
        <details class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 cursor-pointer">
          <summary class="font-bold text-lg text-gray-800">¿Qué edades atienden?</summary>
          <p class="mt-4 text-gray-600">Recibimos niños desde los 43 días de nacidos (lactantes) hasta la etapa de preescolar (4 a 6 años aproximadamente).</p>
        </details>
      </div>
    </section>

  </main>

  <footer class="bg-gray-900 text-gray-400 py-12 text-center text-sm">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-3 gap-8 mb-8 text-left">
      <div>
        <h4 class="text-white font-bold mb-4">Contacto</h4>
        <p>Tel: +52 998 241 5799</p>
        <p>Lunes a Viernes: 7:00 a.m. – 5:00 p.m.</p>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">Ubicación</h4>
        <p>Región 91, Manzana 48, Lote 8, Calle 38 Pte., C.P. 77516, Cancún, Q.R.</p>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">Redes Sociales</h4>
        <a href="https://www.facebook.com/p/Estancia-Infantil-MIS-PEKES-100063553933907/" class="hover:text-teal-400 transition" target="_blank" rel="noopener noreferrer">Facebook Oficial</a>
      </div>
    </div>
    <div class="border-t border-gray-800 pt-8">
      <p>© 2026 Estancia Infantil "Mis Pekes". Todos los derechos reservados.</p>
    </div>
  </footer>
</Layout>
